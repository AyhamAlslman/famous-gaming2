<section class="content auth-page-content">
  <div class="container">
    <div class="auth-shell">
      <div class="auth-card">
        <span class="auth-eyebrow">Account</span>
        <h1>Login</h1>
        <p class="auth-help-text">Use your customer email or admin username.</p>
        <form method="POST" action="/login" class="auth-form">
          <input type="hidden" name="redirect" value="<%= redirect %>">
          <div class="form-group">
            <label class="form-label">Email or username</label>
            <input type="text" name="login_identifier" class="form-control" required autofocus>
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn auth-submit-btn">Login</button>
        </form>
        <div class="auth-links auth-links-stacked">
          <a href="/register?redirect=<%= encodeURIComponent(redirect) %>">Create account</a>
        </div>
      </div>
    </div>
  </div>
</section>
