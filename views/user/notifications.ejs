<section class="hero notifications-hero"><div class="container"><h1>Notifications</h1><p>Your booking, store, and support updates.</p></div></section>
<section class="content notifications-content">
  <div class="container notifications-shell">
    <div class="notifications-toolbar">
      <div><span class="ticket-label">Notifications</span><h2>All Notifications</h2><p><%= unreadCount %> unread</p></div>
      <% if (unreadCount > 0) { %>
        <form method="POST" action="/notifications"><input type="hidden" name="action" value="mark_all_read"><button class="btn payment-secondary-btn">Mark all read</button></form>
      <% } %>
    </div>
    <% if (!notifications.length) { %>
      <div class="notifications-empty"><h3>No notifications</h3><p>You do not have notifications yet.</p></div>
    <% } else { %>
      <div class="notifications-list">
        <% notifications.forEach(function(item) { %>
          <article class="notification-card <%= item.is_read ? 'is-read' : 'is-unread' %>">
            <div class="notification-card-main">
              <span class="smart-notification-badge"><%= item.notification_type %></span>
              <div class="notification-card-head"><h3><%= item.title %></h3><% if (!item.is_read) { %><span class="notification-dot"></span><% } %></div>
              <p><%= item.message %></p>
              <span class="notification-time"><%= format.formatDate(item.created_at) %></span>
            </div>
            <div class="notification-card-actions">
              <% if (item.action_url) { const notificationUrl = String(item.action_url).replace(/^\/+/, ''); %><a class="btn btn-small" href="/<%= notificationUrl %>">View</a><% } %>
              <% if (!item.is_read) { %>
                <form method="POST" action="/notifications"><input type="hidden" name="action" value="mark_read"><input type="hidden" name="notification_id" value="<%= item.id %>"><button class="btn btn-small payment-secondary-btn">Mark read</button></form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
