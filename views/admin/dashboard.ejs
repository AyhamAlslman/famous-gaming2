<section class="content admin-content">
  <div class="container">
    <div class="admin-page-heading">
      <div><span class="ticket-label">Admin</span><h1>Dashboard</h1></div>
    </div>
    <div class="dashboard-grid">
      <% Object.entries(stats).forEach(function(entry) { %>
        <article class="stat-card"><span><%= entry[0].replace(/_/g, ' ') %></span><strong><%= entry[1] %></strong></article>
      <% }) %>
    </div>
    <div class="admin-grid-two">
      <section class="admin-panel">
        <h2>Recent bookings</h2>
        <div class="responsive-table-wrapper">
          <table class="minimal-data-table"><thead><tr><th>ID</th><th>Customer</th><th>Room</th><th>Date</th><th>Status</th></tr></thead><tbody>
            <% bookings.forEach(function(booking) { %>
              <tr><td><%= booking.id %></td><td><%= booking.customer_name %></td><td><%= booking.room_name %></td><td><%= format.formatDate(booking.booking_date) %></td><td><%= booking.status %></td></tr>
            <% }) %>
          </tbody></table>
        </div>
      </section>
      <section class="admin-panel">
        <h2>Recent complaints</h2>
        <% complaints.forEach(function(complaint) { %>
          <article class="store-order-card"><strong><%= complaint.customer_name %></strong><p><%= complaint.message %></p></article>
        <% }) %>
      </section>
    </div>
  </div>
</section>
