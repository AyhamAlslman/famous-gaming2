{
  "name": "famous-gaming-node",
  "version": "1.0.0",
  "description": "Node.js MVC rewrite of the FAMOUS GAMING booking app with PostgreSQL.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
